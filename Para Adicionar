function extrairPercentagemTonerDoHTML(html) {
  const match = html.match(/(\d{1,3})%/);
  return match ? parseInt(match[1]) : null;
}

async function testarToner(ip, id) {
  const div = el(id);
  div.innerHTML = "A testar...";
  try {
    const res = await window.electronAPI.getPrinterHTML(ip);
    if (!res || !res.body) {
      div.innerHTML = "N/D";
      return;
    }
    const percent = extrairPercentagemTonerDoHTML(res.body);
    if (percent == null) {
      div.innerHTML = "N/D";
    } else {
      div.innerHTML = percent + "%";
    }
  } catch {
    div.innerHTML = "Erro";
  }
}

